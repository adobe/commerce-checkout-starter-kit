# Populated automatically after Developer Console association + `aio app build`
# (see README.md "Install" section). Used by the AIO_COMMERCE_AUTH_IMS_* powered install step.

# Required if webhooks are used and signature verification is enabled
COMMERCE_WEBHOOKS_PUBLIC_KEY=

# Required by `npm run get-shipping-carriers` (a local dev helper, not part of the App
# Management install workflow) — @adobe/aio-commerce-lib-api's resolveCommerceHttpClientParams
# reads these directly from process.env.
# e.g. https://my-store.example.com (PaaS) or https://<tenant>.api.commerce.adobe.com/<tenant-id> (SaaS)
AIO_COMMERCE_API_BASE_URL=

# Auth for get-shipping-carriers — reuses the same AIO_COMMERCE_AUTH_IMS_* credentials the
# install step is populated with after association; no separate config needed for SaaS or for
# PaaS IMS auth.
# For PaaS with a Commerce integration instead of IMS, use these in place of AIO_COMMERCE_AUTH_IMS_*:
#AIO_COMMERCE_AUTH_INTEGRATION_CONSUMER_KEY=
#AIO_COMMERCE_AUTH_INTEGRATION_CONSUMER_SECRET=
#AIO_COMMERCE_AUTH_INTEGRATION_ACCESS_TOKEN=
#AIO_COMMERCE_AUTH_INTEGRATION_ACCESS_TOKEN_SECRET=
