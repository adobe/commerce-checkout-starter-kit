{
  "name": "commerce-checkout-starter-kit",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@vitest/coverage-v8": "^4.0.7",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.0",
    "ultracite": "^7.0.0",
    "vitest": "^4.0.7"
  },
  "scripts": {
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint:check": "npx biome lint .",
    "lint": "npx biome lint --write .",
    "format:check": "npx biome format .",
    "format": "npx biome format --write .",
    "code:check": "npx biome check .",
    "code:fix": "npx biome check --write ."
  },
  "engines": {
    "node": "^24.0.0"
  },
  "lint-staged": {
    "*": [
      "npm run code:fix"
    ]
  }
}
