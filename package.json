{
  "name": "@adobe/commerce-checkout-starter-kit",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "test": "npm test --workspaces",
    "code:check": "npm run code:check --workspaces",
    "code:fix": "npm run code:fix --workspaces"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "workspaces": [
    "apps/*",
    "scripts"
  ],
  "lint-staged": {
    "*": [
      "npm run code:fix"
    ]
  },
  "@parcel/resolver-default": {
    "packageExports": true
  }
}
